# OpenAI
OPENAI_API_KEY=sk-...

# Meta WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
VERIFY_TOKEN=your_custom_verify_token
APP_SECRET=

# Supabase (use service role key on backend)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Optional: pin to one org UUID after migration
DEFAULT_ORGANIZATION_ID=

# Company display name fallback
COMPANY_NAME=Your Company Name

# RAG — use your existing Pinecone index (no document tables in Supabase)
RAG_PROVIDER=pinecone
PINECONE_API_KEY=
PINECONE_HOST=          # from Pinecone console → your index → Host
PINECONE_INDEX_NAME=    # or use HOST (serverless indexes need HOST)
PINECONE_NAMESPACE=     # leave empty if you don't use namespaces
PINECONE_TEXT_METADATA_KEY=text
# Must match the model used when you built the Pinecone index:
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
